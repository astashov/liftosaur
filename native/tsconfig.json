{
  "extends": "@react-native/typescript-config",
  "compilerOptions": {
    "types": [
      "jest"
    ],
    "lib": [
      "es2019",
      "es2020",
      "dom"
    ],
    "baseUrl": ".",
    "paths": {
      "@shared/*": [
        "../src/*"
      ],
      "@crossplatform/*": [
        "../crossplatform/*"
      ],
      "react-native": [
        "./node_modules/react-native"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "nativewind-env.d.ts",
    "../crossplatform/**/*.tsx"
  ],
  "exclude": [
    "**/node_modules",
    "**/Pods"
  ]
}