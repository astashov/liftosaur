{
  "extends": "@react-native/typescript-config",
  "compilerOptions": {
    "types": [
      "jest",
      "nativewind/types"
    ],
    "lib": [
      "es2019",
      "es2020",
      "dom"
    ],
    "baseUrl": ".",
    "paths": {
      "@shared/*": [
        "../src/*"
      ],
      "@crossplatform/*": [
        "../crossplatform/*"
      ],
      "react-native": [
        "./node_modules/react-native"
      ],
      "react-native-svg": [
        "./node_modules/react-native-svg"
      ],
      "dequal": [
        "../node_modules/dequal"
      ],
      "react-native-safe-area-context": [
        "./node_modules/react-native-safe-area-context"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "nativewind-env.d.ts",
    "../crossplatform/**/*.tsx",
    "../src/types/**/*.d.ts"
  ],
  "exclude": [
    "**/node_modules",
    "**/Pods"
  ]
}