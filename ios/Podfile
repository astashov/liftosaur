# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'Liftosaur' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )

    # RNLiveMarkdown 0.1.x podspec is missing the ReactCommon/jsitooling header search path
    # required by RN 0.84 (its transitive include of <jsireact/JSIExecutor.h> pulls in
    # <react/runtime/JSRuntimeBindings.h>, which lives under jsitooling/).
    rn_common_dir = File.join(__dir__, '..', 'node_modules', 'react-native', 'ReactCommon')
    rn_common_relative = Pathname.new(rn_common_dir).relative_path_from(installer.sandbox.root).to_s
    installer.pods_project.targets.each do |target|
      next unless target.name == 'RNLiveMarkdown'
      target.build_configurations.each do |config|
        config.build_settings['HEADER_SEARCH_PATHS'] ||= '$(inherited)'
        config.build_settings['HEADER_SEARCH_PATHS'] = [
          config.build_settings['HEADER_SEARCH_PATHS'],
          "\"$(PODS_ROOT)/#{rn_common_relative}/jsitooling\"",
        ].join(' ')
      end
    end

    # Xcode 26 / iOS 26 SDK treats netinet6/in6.h as a private framework header.
    # RollbarNotifier 3.3.3 imports it redundantly (netinet/in.h already covers it).
    rollbar_file = File.join(__dir__, 'Pods', 'RollbarNotifier', 'RollbarNotifier',
                             'Sources', 'RollbarNotifier', 'RollbarReachability.m')
    if File.exist?(rollbar_file)
      text = File.read(rollbar_file)
      patched = text.gsub(/^#import <netinet6\/in6\.h>\n/, '')
      if text != patched
        File.chmod(0644, rollbar_file)
        File.write(rollbar_file, patched)
        Pod::UI.puts "Patched RollbarReachability.m for iOS 26 SDK compatibility".yellow
      end
    end
  end
end
